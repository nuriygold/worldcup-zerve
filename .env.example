# World Cup 2026 Win Probability Engine — ZerveHack
# Copy to .env and fill in real values

# Polymarket API (proxy through backend only — never expose to client)
POLYMARKET_API_BASE=https://gamma-api.polymarket.com

# Redis (optional — falls back to in-memory cache)
REDIS_HOST=localhost
REDIS_PORT=6379

# Frontend API URL
VITE_API_URL=http://localhost:8000

# Zerve deployment (fill in from Zerve dashboard)
ZERVE_API_KEY=
ZERVE_PROJECT_ID=
